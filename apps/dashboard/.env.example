NEXT_PUBLIC_API_BASE_URL=https://api-voc.example.com
NEXT_PUBLIC_VOC_API_BASE_URL=https://api-voc.example.com
VOC_API_INTERNAL_BASE_URL=http://127.0.0.1:8088
VOC_API_INTERNAL_HOST=api-voc.example.com

# Agent LLM
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash 

# Feishu push
FEISHU_WEBHOOK_URL=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_CHAT_ID=

# Email push. SMTP_* / MAIL_* aliases are also supported in code.
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=sender@example.com
EMAIL_SMTP_PASS=
EMAIL_FROM="VOC Review Insight Agent <sender@example.com>"

# Scheduled email workflow
EMAIL_WORKFLOW_SECRET=
EMAIL_WORKFLOW_RECIPIENTS=quality@example.com
EMAIL_WORKFLOW_CLUSTER_KEYS=
EMAIL_WORKFLOW_MAX_CLUSTERS=3

DEEPSEEK_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_API=your_deepseek_api_key
